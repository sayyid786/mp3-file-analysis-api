# Copy this file to .env and fill in the values appropriate for your environment

# Application Environment
# Options: development, staging, production
NODE_ENV=development

# Logging Configuration
# Options: silly, debug, verbose, info, warn, error
LOG_LEVEL=silly

# Server Configuration
# Port the server will listen on
SERVER_PORT=8000

# Server URL for identification
SERVER_URL=localhost:8000

# Enable secure cookies (use true in production with HTTPS)
SERVER_SECURE_COOKIES=false
