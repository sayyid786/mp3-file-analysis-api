    "name": "Sayyid Rasool",
    "email": "sayyidrasool0@gmail.com"
  },
  "main": "src/app.ts",
  "scripts": {
    "start": "nodemon --exec 'ts-node --require dotenv/config' src/app.ts",
    "test": "cross-env NODE_OPTIONS='--require ts-node/register/transpile-only' nyc --reporter=html --check-coverage mocha --require dotenv/config 'test/**/*.test.ts'",
    "build": "tsc",
    "prettier": "prettier \"**/*.+(js|json|css|ts|md)\"",
    "format": "npm run prettier -- --write",
    "check-format": "npm run prettier -- --list-different",
    "check-compile": "tsc --noEmit",
    "lint": "eslint .",
    "pre-push": "npm-run-all check-format check-compile lint"
  },
  "dependencies": {
    "@types/stoppable": "^1.1.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "stoppable": "^1.1.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/sinon": "^21.0.0",
    "@types/sinon-chai": "^4.0.0",
    "@types/sinon-express-mock": "^1.3.12",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "sinon": "^21.0.2",
    "sinon-chai": "^4.0.1",
    "sinon-express-mock": "^2.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "overrides": {
    "diff": "8.0.3",
    "serialize-javascript": "7.0.4"
  }
}
