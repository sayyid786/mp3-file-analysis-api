{
  "name": "mp3-file-analysis-api",
  "version": "1.0.0",
  "description": "An API that analysis mp3 files",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sayyid786/mp3-file-analysis-api.git"
  },
  "license": "UNLICENSED",
